{
  "type": "isekai_api:apply_worldshape_structures",
  "worldshape": {
    "dimension": "minecraft:overworld",

    "playable_range": {
      "min_y": 80,
      "max_y": 300,
      "distribution": "trapezoid"
    },

    "surface_anchor": { "type": "isekai:world_surface" },

    "ore_strategy":       { "type": "isekai:identity" },
    "structure_strategy": { "type": "isekai:identity" },
    "mob_spawn_strategy": { "type": "isekai:identity" },

    "default_structure_predicate": { "type": "isekai:always" },

    "exclusions": {
      "structures": [
        "minecraft:monument",
        "minecraft:shipwreck",
        "minecraft:shipwreck_beached",
        "minecraft:buried_treasure",
        "minecraft:ocean_ruin_cold",
        "minecraft:ocean_ruin_warm"
      ]
    }
  }
}
